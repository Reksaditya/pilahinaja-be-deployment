generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id         Int      @id @default(autoincrement())
  username   String
  email      String   @unique
  password   String
  titleId    Int?
  created_at DateTime @default(now())

  title            Title?            @relation(fields: [titleId], references: [id])
  user_xp          UserXP[]
  user_points      UserPoints[]
  riwayat          Riwayat[]
  user_achievement UserAchievement[]
  penukaran_reward PenukaranReward[]
  komunitas_dibuat Komunitas[]       @relation("KomunitasCreator")
  anggota          Anggota[]
  post             Post[]

  @@map("users")
}

model UserXP {
  id         Int      @id @default(autoincrement())
  userId     Int
  xp         Int
  created_at DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@map("user_xp")
}

model UserPoints {
  id         Int      @id @default(autoincrement())
  userId     Int
  points     Int
  created_at DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@map("user_points")
}

model Title {
  id         Int    @id @default(autoincrement())
  nama_title String
  min_xp     Int

  users User[]

  @@map("titles")
}

model Kategori {
  id            Int     @id @default(autoincrement())
  nama_kategori String
  deskripsi     String?

  sampah Sampah[]

  @@map("kategori_sampah")
}

model Sampah {
  id         Int     @id @default(autoincrement())
  nama       String
  kategoriId Int
  xp         Int
  point      Int
  deskripsi  String?

  kategori           Kategori           @relation(fields: [kategoriId], references: [id])
  panduan_daur_ulang PanduanDaurUlang[]
  riwayat            Riwayat[]

  @@map("sampah")
}

model PanduanDaurUlang {
  id       Int    @id @default(autoincrement())
  sampahId Int
  hasil    String
  langkah  String

  sampah Sampah @relation(fields: [sampahId], references: [id])

  @@map("panduan_daur_ulang")
}

model Riwayat {
  id       Int      @id @default(autoincrement())
  userId   Int
  sampahId Int
  jumlah   Int
  tanggal  DateTime @default(now())
  xp       Int
  point    Int

  user   User   @relation(fields: [userId], references: [id])
  sampah Sampah @relation(fields: [sampahId], references: [id])

  @@map("riwayat")
}

model Achievement {
  id               Int     @id @default(autoincrement())
  nama_achievement String
  deskripsi        String?
  target           Int
  reward_xp        Int

  user_achievement UserAchievement[]

  @@map("achievement")
}

model UserAchievement {
  idt              Int      @id @default(autoincrement())
  userId           Int
  archievementId   Int
  tanggal_tercapai DateTime @default(now())

  user        User        @relation(fields: [userId], references: [id])
  achievement Achievement @relation(fields: [archievementId], references: [id])

  @@map("user_achievement")
}

model Reward {
  id    Int    @id @default(autoincrement())
  nama  String
  jenis String
  poin  Int
  stok  Int

  penukaran_reward PenukaranReward[]

  @@map("reward")
}

model PenukaranReward {
  id                Int      @id @default(autoincrement())
  userId            Int
  rewardId          Int
  tanggal_penukaran DateTime @default(now())
  status            String

  user   User   @relation(fields: [userId], references: [id])
  reward Reward @relation(fields: [rewardId], references: [id])

  @@map("penukaran_reward")
}

model Komunitas {
  id             Int      @id @default(autoincrement())
  nama_komunitas String
  deskripsi      String?
  created_by     Int
  created_at     DateTime @default(now())

  creator User @relation("KomunitasCreator", fields: [created_by], references: [id])

  anggota Anggota[]
  post    Post[]

  @@map("komunitas")
}

model Anggota {
  id          Int      @id @default(autoincrement())
  komunitasId Int
  userId      Int
  role        String
  joined_at   DateTime @default(now())

  komunitas Komunitas @relation(fields: [komunitasId], references: [id])
  user      User      @relation(fields: [userId], references: [id])

  @@map("anggota")
}

model Post {
  id          Int      @id @default(autoincrement())
  komunitasId Int
  userId      Int
  title       String
  desc        String
  media       String?
  created_at  DateTime @default(now())

  komunitas Komunitas @relation(fields: [komunitasId], references: [id])
  user      User      @relation(fields: [userId], references: [id])

  @@map("post")
}
