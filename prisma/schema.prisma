generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  username         String
  email            String            @unique
  password         String
  created_at       DateTime          @default(now())
  id               Int               @id @default(autoincrement())
  titleId          Int?
  anggota          Anggota[]
  komunitas_dibuat Komunitas[]       @relation("KomunitasCreator")
  penukaran_reward PenukaranReward[]
  post             Post[]
  riwayat          Riwayat[]
  user_achievement UserAchievement[]
  user_points      UserPoints[]
  user_xp          UserXP[]
  title            Title?            @relation(fields: [titleId], references: [id])

  @@map("users")
}

model UserXP {
  xp         Int
  created_at DateTime @default(now())
  id         Int      @id @default(autoincrement())
  userId     Int
  user       User     @relation(fields: [userId], references: [id])

  @@map("user_xp")
}

model UserPoints {
  points     Int
  created_at DateTime @default(now())
  id         Int      @id @default(autoincrement())
  userId     Int
  user       User     @relation(fields: [userId], references: [id])

  @@map("user_points")
}

model Title {
  nama_title String
  min_xp     Int
  id         Int    @id @default(autoincrement())
  users      User[]

  @@map("titles")
}

model Kategori {
  nama_kategori String
  deskripsi     String?
  id            Int      @id @default(autoincrement())
  sampah        Sampah[]

  @@map("kategori_sampah")
}

model Sampah {
  nama               String
  xp                 Int
  point              Int
  deskripsi          String?
  id                 Int                @id @default(autoincrement())
  kategoriId         Int
  panduan_daur_ulang PanduanDaurUlang[]
  riwayat            Riwayat[]
  kategori           Kategori           @relation(fields: [kategoriId], references: [id])

  @@map("sampah")
}

model PanduanDaurUlang {
  hasil    String
  langkah  String
  id       Int    @id @default(autoincrement())
  sampahId Int
  sampah   Sampah @relation(fields: [sampahId], references: [id])

  @@map("panduan_daur_ulang")
}

model Riwayat {
  jumlah   Int
  tanggal  DateTime @default(now())
  xp       Int
  point    Int
  id       Int      @id @default(autoincrement())
  sampahId Int
  userId   Int
  sampah   Sampah   @relation(fields: [sampahId], references: [id])
  user     User     @relation(fields: [userId], references: [id])

  @@map("riwayat")
}

model Achievement {
  nama_achievement String
  deskripsi        String?
  target           Int
  reward_xp        Int
  id               Int               @id @default(autoincrement())
  user_achievement UserAchievement[]

  @@map("achievement")
}

model UserAchievement {
  tanggal_tercapai DateTime    @default(now())
  archievementId   Int
  idt              Int         @id @default(autoincrement())
  userId           Int
  achievement      Achievement @relation(fields: [archievementId], references: [id])
  user             User        @relation(fields: [userId], references: [id])

  @@map("user_achievement")
}

model Reward {
  nama             String
  jenis            String
  poin             Int
  stok             Int
  id               Int               @id @default(autoincrement())
  penukaran_reward PenukaranReward[]

  @@map("reward")
}

model PenukaranReward {
  tanggal_penukaran DateTime @default(now())
  status            String
  id                Int      @id @default(autoincrement())
  rewardId          Int
  userId            Int
  reward            Reward   @relation(fields: [rewardId], references: [id])
  user              User     @relation(fields: [userId], references: [id])

  @@map("penukaran_reward")
}

model Komunitas {
  nama_komunitas String
  deskripsi      String?
  created_by     Int
  created_at     DateTime  @default(now())
  id             Int       @id @default(autoincrement())
  anggota        Anggota[]
  creator        User      @relation("KomunitasCreator", fields: [created_by], references: [id])
  post           Post[]

  @@map("komunitas")
}

model Anggota {
  role        String
  joined_at   DateTime  @default(now())
  id          Int       @id @default(autoincrement())
  komunitasId Int
  userId      Int
  komunitas   Komunitas @relation(fields: [komunitasId], references: [id])
  user        User      @relation(fields: [userId], references: [id])

  @@map("anggota")
}

model Post {
  title       String
  desc        String
  media       String?
  created_at  DateTime  @default(now())
  id          Int       @id @default(autoincrement())
  komunitasId Int
  userId      Int
  komunitas   Komunitas @relation(fields: [komunitasId], references: [id])
  user        User      @relation(fields: [userId], references: [id])

  @@map("post")
}
